# Email Configuration
EMAIL_DOMAIN=yourtempemail.com
EMAIL_DB_PATH=/home/ubuntu/emails.db

# Server Configuration
SERVER_PORT=8080

# Arduino CLI compile API (POST /api/arduino-compile)
# Body: sketch (main sketch.ino), optional files[] { name, content } for multi-file sketches (basenames only).
# Install: https://arduino.github.io/arduino-cli/ — then e.g. arduino-cli core install arduino:avr
# By default the API uses the same Arduino data dir as your shell (~/.arduino15 or ~/Library/Arduino15).
# Set this only to use a dedicated directory (e.g. on servers):
# ARDUINO_COMPILE_DATA_DIR=/var/lib/arduino-cli-data
# Optional: only if arduino-cli is not on PATH (default is to run `arduino-cli` from PATH)
# ARDUINO_CLI=/opt/arduino-cli/arduino-cli
# ARDUINO_COMPILE_SKETCH_MAX_BYTES=51200
# ARDUINO_COMPILE_TIMEOUT_SEC=600
# Optional: run compiles inside a container (see docker/arduino-compile/Dockerfile).
# Image includes arduino:avr + Earle Philhower rp2040:rp2040 (Pico / Pico W FQBNs).
# Use podman for rootless/daemonless (same CLI as docker run).
# ARDUINO_DOCKER_IMAGE=arduino-compile:local
# ARDUINO_DOCKER_BINARY=docker   # or: podman
# macOS: Podman needs a running VM (podman machine start). If the socket is missing, use Docker Desktop
# and ARDUINO_DOCKER_BINARY=docker, or start Podman: podman machine init && podman machine start
#
# Optional: comma-separated FQBNs advertised in GET /api/arduino-libraries → supportedBoardFQBNs (default list includes ESP32 if unset).
# ARDUINO_SUPPORTED_BOARD_FQBNS=arduino:avr:uno,rp2040:rp2040:rpipico,esp32:esp32:esp32c3
# Optional: if true, POST /api/arduino-compile rejects board unless it appears in the list above (or default list when env unset).
# ARDUINO_ENFORCE_BOARD_ALLOWLIST=false
#
# Optional: POST /api/arduino-libraries/install (host only; mutates ARDUINO_DIRECTORIES_DATA). Disabled when ARDUINO_DOCKER_IMAGE is set.
# ARDUINO_LIB_INSTALL_ENABLED=false
# ARDUINO_LIB_INSTALL_REQUIRE_ALLOWLIST=true

# ── ESP32 QEMU Simulation (POST /api/arduino-simulate/start, GET /api/arduino-simulate/stream) ──
# Runs compiled ESP32 firmware in QEMU for interactive simulation (serial I/O, GPIO).
# ESP32 boards compile with FlashMode=dio automatically (QEMU doesn't support QIO).
# Supported machines: esp32c3 (riscv32), esp32 (xtensa), esp32s3 (xtensa).
#
# Compile artifacts (job store) — firmware stays on disk, browser gets jobId (no 4MB base64 round-trip):
# ARDUINO_JOB_DIR=/tmp/arduino-jobs         # where compile artifacts are stored
# ARDUINO_JOB_TTL_SEC=300                    # auto-delete after 5 min (default)
# ARDUINO_JOB_SWEEP_SEC=60                   # cleanup sweep interval (default)
#
# QEMU instance limits:
# QEMU_MAX_INSTANCES=20                      # max concurrent QEMU processes (default)
# QEMU_INSTANCE_TIMEOUT=600                  # per-instance timeout in seconds (default 10 min)
# QEMU_SWEEP_INTERVAL=60                     # how often to check for stale instances (default 60s)
#
# Option A — Docker mode (recommended for servers):
#   docker build -t qemu-esp32:local -f docker/qemu-esp32/Dockerfile .
# QEMU_DOCKER_IMAGE=qemu-esp32:local
# QEMU_DOCKER_BINARY=docker   # or: podman
#
# Option B — Host mode (QEMU binaries on PATH):
#   Download from: https://github.com/espressif/qemu/releases
# QEMU_RISCV32_BINARY=qemu-system-riscv32    # ESP32-C3 (RISC-V)
# QEMU_XTENSA_BINARY=qemu-system-xtensa      # ESP32 / ESP32-S3 (Xtensa)
# ── Raspberry Pi 3 QEMU Simulation ──
# Boots Raspberry Pi OS Lite in QEMU. Uses init=/bin/sh (skips systemd — boots in ~10s).
# NOTE: Docker mode requires a Linux host. macOS Docker Desktop cannot bridge QEMU serial TCP.
#
# Option A — Docker mode (Linux server, recommended):
#   docker build -t qemu-pi3:local -f docker/qemu-pi3/Dockerfile .
#   Image includes: QEMU 10.x + Pi OS Lite + kernel8.img + device tree (~3.8GB)
# PI_QEMU_DOCKER_IMAGE=qemu-pi3:local
# PI_QEMU_DOCKER_BINARY=docker               # or: podman
#
# Option B — Host mode (QEMU + Pi OS files on disk):
#   Install: apt install qemu-system-arm qemu-utils
#   Download Pi OS Lite: https://www.raspberrypi.com/software/operating-systems/
#   Extract kernel8.img and bcm2710-rpi-3-b.dtb from the boot partition.
# QEMU_AARCH64_BINARY=qemu-system-aarch64
# PI_KERNEL_PATH=/opt/pi/kernel8.img
# PI_DTB_PATH=/opt/pi/bcm2710-rpi-3-b.dtb
# PI_SD_IMAGE_PATH=/opt/pi/raspios.img
#
# Limits:
# PI_MAX_INSTANCES=5                          # max concurrent Pi instances (default: 5)
# PI_INSTANCE_TIMEOUT=1800                    # per-instance timeout seconds (default: 30 min)
# PI_OVERLAY_DIR=/tmp/pi-overlays             # qcow2 overlay directory (default: system temp)
# PI_SWEEP_INTERVAL=60                        # cleanup sweep interval (default 60s)

# Pastebin + Cloudflare (run ./scripts/pastebin-cf-setup.sh first)
PASTEBIN_STORAGE=r2
# Optional: full R2 endpoint. If omitted, built from R2_ACCOUNT_ID.
# R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pastebin-storage
PASTEBIN_DB_PATH=/tmp/pastebin.db
PASTEBIN_BASE_URL=http://localhost:8080
# D1 (if using D1 proxy Worker)
# PASTEBIN_D1_DATABASE_ID=
# D1_API_URL=
# D1_API_KEY=













