# Email Configuration
EMAIL_DOMAIN=yourtempemail.com
EMAIL_DB_PATH=/home/ubuntu/emails.db

# Server Configuration
SERVER_PORT=8080

# Pastebin + Cloudflare (run ./scripts/pastebin-cf-setup.sh first)
PASTEBIN_STORAGE=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pastebin-storage
# Alternative: local SQLite for metadata (no D1 Worker needed)
# PASTEBIN_DB_PATH=/path/to/pastebin.db
# D1 (if using D1 proxy Worker)
# PASTEBIN_D1_DATABASE_ID=
# D1_API_URL=
# D1_API_KEY=













